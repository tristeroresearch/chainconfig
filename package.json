{
    "name": "@tristeroresearch/chainconfig",
    "version": "1.0.0",
    "description": "Chain configuration and integrity checker for Create5 project",
    "type": "module",
    "scripts": {
        "check": "node scripts/integrity_check.mjs check",
        "verify-rpcs": "node scripts/integrity_check.mjs verify-rpcs",
        "verify-contracts": "node scripts/integrity_check.mjs verify-contracts",
        "fix": "node scripts/integrity_check.mjs fix",
        "sort-keys": "node scripts/sort_chain_keys.mjs --write",
        "check-key-order": "node scripts/sort_chain_keys.mjs --check",
        "format": "prettier --write .",
        "check-format": "prettier --check .",
        "dump-keys": "node scripts/dump_chain_keys.mjs",
        "install-hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit",
        "fetch-gaszip": "node scripts/fetch_gaszip_chains.mjs",
        "fetch-chainlist": "node scripts/fetch_chainlist_rpcs.mjs"
    },
    "keywords": [
        "blockchain",
        "config",
        "multichain"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "ethers": "^5.7.2",
        "prettier": "^3.3.3",
        "yargs": "^17.7.2"
    }
}
